<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- =========================================== -->
    <!-- TEMEL İZİNLER                               -->
    <!-- =========================================== -->
    
    <!-- İnternet bağlantısı (Firebase, API çağrıları) -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Ağ durumunu kontrol etme -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- =========================================== -->
    <!-- BİLDİRİM İZİNLERİ                            -->
    <!-- =========================================== -->
    
    <!-- Android 13+ için bildirim izni -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Bildirim titreşimi -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Uyku modunda bildirim gönderme -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- =========================================== -->
    <!-- DOSYA SİSTEMİ İZİNLERİ                       -->
    <!-- =========================================== -->
    
    <!-- Harici depolama okuma (API 29- için) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    
    <!-- Harici depolama yazma (API 29- için) -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" 
        android:maxSdkVersion="28" />
    
    <!-- Geniş depolama erişimi (API 30+ için) -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    
    <!-- =========================================== -->
    <!-- ARKA PLAN SERVİS İZİNLERİ                    -->
    <!-- =========================================== -->
    
    <!-- Arka plan servisi çalıştırma -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- Cihaz yeniden başlatıldığında uygulamayı başlat -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Zamanlanmış görevler için -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    
    <!-- =========================================== -->
    <!-- KAMERA İZİNLERİ (Opsiyonel - ilerisi için)   -->
    <!-- =========================================== -->
    
    <!-- <uses-permission android:name="android.permission.CAMERA" /> -->
    
    <!-- =========================================== -->
    <!-- UYGULAMA BİLGİLERİ                           -->
    <!-- =========================================== -->
    
    <application
        android:name="${applicationName}"
        android:label="servobiz"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="true"
        android:theme="@style/LaunchTheme"
        android:requestLegacyExternalStorage="true"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:usesCleartextTraffic="true">
        
        <!-- ======================================= -->
        <!-- ANA ACTIVITY                             -->
        <!-- ======================================= -->
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <!-- Normal tema (Flutter başlatılırken) -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />
            
            <!-- Uygulama başlatıcı -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            
        </activity>
        
        <!-- ======================================= -->
        <!-- BİLDİRİM SERVİSLERİ                      -->
        <!-- ======================================= -->
        
        <!-- Zamanlanmış bildirim alıcısı -->
        <receiver android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false" />
        
        <!-- Cihaz başlatıldığında bildirimleri yeniden planla -->
        <receiver android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
        
        <!-- Ön plan servisi (arka plan bildirimleri için) -->
        <service android:name="com.dexterous.flutterlocalnotifications.ForegroundService"
            android:exported="false" />
        
        <!-- ======================================= -->
        <!-- FIREBASE SERVİSLERİ                      -->
        <!-- ======================================= -->
        
        <!-- Firebase bildirim servisi -->
        <service android:name="com.google.firebase.messaging.FirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        
        <!-- Firebase bildirim ikonu -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_ic_notification" />
        
        <!-- Firebase bildirim kanalı -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="high_importance_channel" />
        
        <!-- Firebase bildirim rengi (opsiyonel) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_color"
            android:resource="@color/notification_color" />
        
        <!-- ======================================= -->
        <!-- DOSYA SAĞLAYICI (File Provider)          -->
        <!-- ======================================= -->
        
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        
        <!-- ======================================= -->
        <!-- METADATA                                 -->
        <!-- ======================================= -->
        
        <!-- Flutter embedding versiyonu (SİLMEYİN!) -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
        
    </application>
    
    <!-- =========================================== -->
    <!-- SORGULAR (Queries)                          -->
    <!-- =========================================== -->
    
    <!-- Metin işleme için gerekli -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
        
        <!-- Tarayıcı sorgusu -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        
        <!-- E-posta sorgusu -->
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>
    
</manifest>
